<?xml version="1.0"?>
<robot name="stanford_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">
<!--참고문헌1 https://wiki.ros.org/urdf/Tutorials-->
<!--참고문헌2 https://wiki.ros.org/urdf/XML/joint-->


    <!--기본 파라미터-->
    <xacro:property name="pi" value="3.1415926535897932384626" /xacro>

    <!--기본 치수-->
    <xacro:property name="base_radius" value="0.12" />
    <xacro:property name="base_height" value="0.08" />

    <xacro:property name="link_1_length" value="0.25" />
    <xacro:property name="link_2_length" value="0.25" />

    <xacro:property name="link_radius" value="0.04" />
    <xacro:property name="ee_radius" value="0.03" />

    <!--질량-->
    <xacro:property name="base_mass" value="5.0" />
    <xacro:property name="link_1_mass" value="2.0" />
    <xacro:property name="link_2_mass" value="2.0" />

    <!--관성-->
    <xacro:macro name="cyliner_inertial" params="mass radius length">
        <inertial>
            <mass value="${mass}"/>
            <origin xyz="0 0 ${length/2.0}" rpy="0 0 0"/>
            <inertia 
            ixx="0.0" 
            ixy="0.0" 
            ixz="0.0" 
            iyy="0.0" 
            iyz="0.0" 
            izz="0.0"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="box_inertial" params="mass x y z">
        <mass value="${mass}"/>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <inertial>
            <inertia 
            ixx="0.0" 
            ixy="0.0" 
            ixz="0.0" 
            iyy="0.0" 
            iyz="0.0" 
            izz="0.0"/>
        </inertial>
    </xacro:macro>

    <!--ros_control과 연결-->
    <xacro:include filename="$(find stanford_arm_description)/urdf/ros2_control.xacro"/>


    <!--링크 설명들-->
    <link name="base">
        <visual>
            <origin xyz="0.0 0.0 ${base_height/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${base_radius}" length="${base_height}"/>
            </geometry>
            <material name="Gray">
                <color rgba="0.5 0.5 0.5 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${base_height/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${base_radius}" length="${base_height}"/>
            </geometry>
        </collision>
        <xacro:cyliner_inertial mass="${base_mass}" radius="${base_radius}" length="${base_height}">
    </link>

    <link name="link_1">
        <visual>
            <origin xyz="0.0 0.0 ${link_1_length/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${link_radius}" length="${link_1_length}"/>
            </geometry>
            <material name="Gray">
                <color rgba="0.5 0.5 0.5 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${link_1_length/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${link_radius}" length="${link_1_length}"/>
            </geometry>
        </collision>
        <xacro:cyliner_inertial mass="${link_1_mass}" radius="${link_radius}" length="${link_2_length}">
    </link>

    <link name="link_2">
        <visual>
            <origin xyz="0.0 0.0 ${link_2_length/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${link_radius}" length="${link_2_length}"/>
            </geometry>
            <material name="Gray">
                <color rgba="0.5 0.5 0.5 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${link_2_length/2.0}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="${link_radius}" length="${link_2_length}"/>
            </geometry>
        </collision>
        <xacro:cyliner_inertial mass="${link_2_mass}" radius="${link_radius}" length="${link_2_length}">
    </link>

    <!--조인트 설명들-->
    <joint name="joint_1" type="revolute">
        <parent link="base_link"/>
        <child link="link_1"/>
        <origin xyz="0.0 0.0 base_height" rpy="0.0 0.0 0.0"/>
        <axis xyz="0 0 1"/>
        <limit lower="${-pi}" upper="${pi}" effort="80.0" velocity="2.0"/>
        <dynamics damping="0.8" friction="0.2">
    </joint>

    <joint name="joint2" type="revolute">
        <parent link="link1"/>
        <child link="link2"/>
        <origin xyz="0 0 ${link1_length}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="${-pi/2}" upper="${pi/2}" effort="70.0" velocity="2.0"/>
        <dynamics damping="0.8" friction="0.2"/>
    </joint>

    <!--가제보 연결-->
    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find stanford_arm_control)/config/ros2_controllers.yaml</parameters>
        </plugin>
    </gazebo>

</robot>